# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=HVAC-Intelligence API
APP_VERSION=1.0.0
# Enable verbose logging and public /docs without API key
DEBUG=false
ENVIRONMENT=development

# ── Auth (dashboard + admin API) ─────────────────────────────────────────────
# Required. Generate: openssl rand -hex 32
DASHBOARD_API_KEY=
# Stopgap tenant for dashboard API until JWT (matches seed org in migration 005)
DASHBOARD_ORG_ID=00000000-0000-4000-8000-000000000001
# Set true only for local webhook testing without HMAC; never in production
VAPI_WEBHOOK_HMAC_BYPASS=false

# ── Vapi ─────────────────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID=
# Fallback called number when webhook omits business phone (tenant routing)
VAPI_PHONE_NUMBER=

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://hvac_user:changeme@localhost:5432/hvac_intel
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── AI Services ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Embeddings for RAG (use sk-... for live; pc-dev-test uses mock index)
OPENAI_API_KEY=

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Pinecone / RAG ───────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=hvac-knowledge
RAG_MOCK_INDEX_PATH=data/knowledge/.mock_vector_index.json
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
RAG_MMR_LAMBDA=0.5

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CALL_FEATURES=call.features
KAFKA_TOPIC_CHURN_SCORES=churn.scores
KAFKA_TOPIC_HIGH_RISK_ALERTS=alerts.high_risk

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_ARTIFACTS_PATH=./ml/artifacts
CHURN_SCORE_THRESHOLD_HIGH=0.60
CHURN_SCORE_THRESHOLD_CRITICAL=0.80
FEATURE_WINDOW_DAYS=90
SCORING_CADENCE_HOURS=6

# ── Google Calendar + Drive (OAuth) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/oauth/callback
# Fernet key for encrypting OAuth tokens at rest (generate with cryptography.fernet)
GOOGLE_TOKEN_ENCRYPTION_KEY=
FRONTEND_BASE_URL=http://localhost:3000

# ── Jobber (OAuth) ───────────────────────────────────────────────────────────
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations/jobber/oauth/callback

# ── Frontend (Next.js — also set in frontend/.env.local) ─────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=
NEXT_PUBLIC_DASHBOARD_ORG_ID=00000000-0000-4000-8000-000000000001
NEXT_PUBLIC_ORG_NAME=HVAC Intelligence Demo

# ── Observability (docker-compose) ───────────────────────────────────────────
GRAFANA_PASSWORD=admin
