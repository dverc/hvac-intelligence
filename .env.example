# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=HVAC-Intelligence API
APP_VERSION=1.0.0
DEBUG=false

# ── Database (matches docker-compose postgres service) ───────────────────────
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://hvac_user:changeme@localhost:5432/hvac_intel
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── AI Services ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID=

# ── Vector DB (Pinecone) ─────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=hvac-knowledge

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CALL_FEATURES=call.features
KAFKA_TOPIC_CHURN_SCORES=churn.scores
KAFKA_TOPIC_HIGH_RISK_ALERTS=alerts.high_risk

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_ARTIFACTS_PATH=./ml/artifacts
CHURN_SCORE_THRESHOLD_HIGH=0.60
CHURN_SCORE_THRESHOLD_CRITICAL=0.80
FEATURE_WINDOW_DAYS=90
SCORING_CADENCE_HOURS=6

# RAG (local mock index used when Pinecone/OpenAI keys are unset or dev placeholders)
RAG_MOCK_INDEX_PATH=data/knowledge/.mock_vector_index.json
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536
RAG_MMR_LAMBDA=0.5

# Frontend (Next.js dashboard — also set in frontend/.env.local)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Grafana (docker-compose Phase 7)
GRAFANA_PASSWORD=admin
